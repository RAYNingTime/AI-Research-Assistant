# ─── xAI / Grok API ───────────────────────────────────────────────────────────
# Obtain your key at https://console.x.ai/
XAI_API_KEY=your_xai_api_key_here

# ─── Scraping ──────────────────────────────────────────────────────────────────
# Maximum number of characters to keep from each scraped page before sending to
# the model (reduces token usage while preserving meaningful content).
MAX_CHARS_PER_PAGE=8000

# Request timeout in seconds for each HTTP request.
REQUEST_TIMEOUT=30

# ─── Scheduler ─────────────────────────────────────────────────────────────────
# Cron-style schedule for the daily run (default: every day at 07:00 UTC).
# Format:  MINUTE HOUR DOM MONTH DOW
SCHEDULE_CRON=0 7 * * *

# ─── Memory ────────────────────────────────────────────────────────────────────
# Path to the JSON file used to persist summaries across runs.
MEMORY_FILE=memory.json

# ─── Paths ─────────────────────────────────────────────────────────────────────
# CSV file that contains the list of sources to scrape.
SOURCES_CSV=sources.csv
